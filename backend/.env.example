# Server
PORT=4000
# Comma-separated — Next.js falls back to 3001+ if 3000 is already taken.
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Gemini (Google AI Studio) — https://aistudio.google.com/app/apikey — standby fallback
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash-image
AI_TIMEOUT_MS=45000

# Pollinations.ai — https://gen.pollinations.ai/docs — priority image provider,
# tried first; falls back to Gemini above on any failure. Leave blank to run
# Gemini-only.
POLLINATIONS_API_KEY=your-pollinations-api-key
POLLINATIONS_MODEL=flux
POLLINATIONS_BASE_URL=https://gen.pollinations.ai
# Dev/testing only — routes image generation through image.pollinations.ai's
# free, unauthenticated legacy endpoint (no Pollen balance, no API key).
# NEVER set this to true in production (no auth, no uptime guarantee).
POLLINATIONS_FREE_MODE=false

# Supabase — Project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=generations

# Newer Supabase API key format (not currently read by this codebase — kept
# here only so this file mirrors everything in Project Settings > API).
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SECRET_KEY=your-secret-key
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json
